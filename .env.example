# PostgreSQL
# 로컬 Docker: docker compose up -d postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5431/unnie_side?schema=public"
# 로컬에서는 DATABASE_URL과 동일하게 두면 됩니다.
DIRECT_URL="postgresql://postgres:postgres@localhost:5431/unnie_side?schema=public"

# Neon (프로덕션)
# DATABASE_URL = Neon 대시보드의 "Pooled connection" URL
# DIRECT_URL   = Neon 대시보드의 "Direct connection" URL
# DATABASE_URL="postgresql://...@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://...@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js (`openssl rand -base64 32`)
AUTH_SECRET=""

# 배포 환경 기준 URL (Vercel 등) — OAuth·사이트맵·OG 메타에 사용
# AUTH_URL="https://your-domain.vercel.app"
# NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# Google OAuth 2.0 (웹 클라이언트)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
